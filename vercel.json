{
  "version": 2,
  "builds": [
    {
      "src": "api/send.js",
      "use": "@vercel/node"
    },
    {
      "src": "redeem/.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/send",
      "dest": "/api/send.js"
    },
    {
      "src": "/(.)",
      "dest": "/redeem/index.html"
    }
  ]
}
